generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Rol {
  ADMIN
  GERENCIA
  DIRECCION
  FACTURACION
  COORDINADORA
  ADMISIONES
}

enum TipoConector {
  GOOGLE_SHEETS
  REST_API
  POSTGRESQL
  CSV
}

enum EstadoSync {
  EN_PROCESO
  COMPLETADA
  FALLIDA
  PARCIAL
}

enum TipoWidget {
  KPI_CARD
  TABLA_ENTIDADES
  TABLA_SERVICIOS
  CHART_CUMPLIMIENTO_SEMANAL
  CHART_CUMPLIMIENTO_MENSUAL
  CHART_DIAS_SEMANA
  CHART_MIX_PAGADOR
  CHART_TENDENCIA
  CHART_PROYECCION
  AUDITORIA_ALERTAS
}

model Usuario {
  id            String        @id @default(uuid())
  email         String        @unique @db.VarChar(191)
  nombre        String
  passwordHash  String        @map("password_hash")
  rol           Rol
  activo        Boolean       @default(true)
  deletedAt     DateTime?     @map("deleted_at")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")
  refreshTokens RefreshToken[]
  auditLogs     AuditLog[]
  dashboards    Dashboard[]

  @@map("usuarios")
}

model RefreshToken {
  id         String    @id @default(uuid())
  tokenHash  String    @unique @map("token_hash") @db.VarChar(64)
  usuarioId  String    @map("usuario_id")
  usuario    Usuario   @relation(fields: [usuarioId], references: [id])
  expiresAt  DateTime  @map("expires_at")
  revokedAt  DateTime? @map("revoked_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  @@map("refresh_tokens")
}

model Conector {
  id               String           @id @default(uuid())
  nombre           String
  tipo             TipoConector
  config           Json
  activo           Boolean          @default(true)
  frecuenciaSync   String           @default("daily") @map("frecuencia_sync")
  ultimaSync       DateTime?        @map("ultima_sync")
  createdAt        DateTime         @default(now()) @map("created_at")
  updatedAt        DateTime         @updatedAt @map("updated_at")
  sincronizaciones Sincronizacion[]

  @@map("conectores")
}

model Sincronizacion {
  id           String     @id @default(uuid())
  conectorId   String     @map("conector_id")
  conector     Conector   @relation(fields: [conectorId], references: [id])
  estado       EstadoSync
  filasLeidas  Int        @default(0) @map("filas_leidas")
  filasNuevas  Int        @default(0) @map("filas_nuevas")
  errores      Json?
  iniciadaAt   DateTime   @default(now()) @map("iniciada_at")
  finalizadaAt DateTime?  @map("finalizada_at")

  @@map("sincronizaciones")
}

model Dashboard {
  id          String    @id @default(uuid())
  nombre      String
  descripcion String?   @db.Text
  usuarioId   String?   @map("usuario_id")
  usuario     Usuario?  @relation(fields: [usuarioId], references: [id])
  rolDefault  Rol?      @map("rol_default")
  esPublico   Boolean   @default(false) @map("es_publico")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  widgets     Widget[]

  @@map("dashboards")
}

model Widget {
  id          String     @id @default(uuid())
  dashboardId String     @map("dashboard_id")
  dashboard   Dashboard  @relation(fields: [dashboardId], references: [id], onDelete: Cascade)
  tipo        TipoWidget
  titulo      String?
  config      Json       @default("{}")
  posX        Int        @default(0) @map("pos_x")
  posY        Int        @default(0) @map("pos_y")
  ancho       Int        @default(3)
  alto        Int        @default(2)
  orden       Int        @default(0)
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")

  @@map("widgets")
}

model AuditLog {
  id          String    @id @default(uuid())
  usuarioId   String?   @map("usuario_id")
  usuario     Usuario?  @relation(fields: [usuarioId], references: [id])
  accion      String
  entidadTipo String?   @map("entidad_tipo")
  entidadId   String?   @map("entidad_id")
  detalle     Json?
  ip          String?
  createdAt   DateTime  @default(now()) @map("created_at")

  @@index([usuarioId])
  @@index([accion])
  @@index([createdAt])
  @@map("audit_log")
}

// ─── Stage 3: Core Data Models ────────────────────────────────────────────────

enum TipoEntidad {
  EPS
  CONVENIO
  PARTICULAR
  ARL
  OTRO
}

model Entidad {
  id          String      @id @default(uuid())
  nombre      String
  nombresRaw  Json        @map("nombres_raw")
  tipo        TipoEntidad
  esGrupoCaja Boolean     @default(false) @map("es_grupo_caja")
  activa      Boolean     @default(true)
  createdAt   DateTime    @default(now()) @map("created_at")
  atenciones  Atencion[]

  @@index([tipo])
  @@index([nombre])
  @@map("entidades")
}

model Profesional {
  id          String     @id @default(uuid())
  nombre      String
  nombresRaw  Json       @map("nombres_raw")
  esNomina    Boolean    @default(false) @map("es_nomina")
  activo      Boolean    @default(true)
  createdAt   DateTime   @default(now()) @map("created_at")
  atenciones  Atencion[]

  @@map("profesionales")
}

model Servicio {
  id           String     @id @default(uuid())
  nombre       String     @unique @db.VarChar(191)
  categoria    String?
  palabrasClave Json?     @map("palabras_clave")
  tipoConteo   String     @default("unidad") @map("tipo_conteo")
  orden        Int        @default(99)
  createdAt    DateTime   @default(now()) @map("created_at")
  atenciones   Atencion[]

  @@map("servicios")
}

model Atencion {
  id                  String       @id @default(uuid())
  descripcionRaw      String       @map("descripcion_raw") @db.Text
  descripcionNorm     String       @map("descripcion_norm") @db.Text
  fechaDia            DateTime     @map("fecha_dia")
  mesIdx              Int          @map("mes_idx")
  anio                Int
  valorBruto          Decimal      @map("valor_bruto") @db.Decimal(12, 2)
  numeroAutorizacion  String?      @map("numero_autorizacion")
  esTelemetria        Boolean      @default(false) @map("es_telemetria")
  pacienteNombre      String?      @map("paciente_nombre") @db.VarChar(255)
  pacienteDocumento   String?      @map("paciente_documento") @db.VarChar(50)
  hashFila            String       @unique @map("hash_fila") @db.VarChar(64)
  entidadId           String?      @map("entidad_id")
  entidad             Entidad?     @relation(fields: [entidadId], references: [id])
  profesionalId       String?      @map("profesional_id")
  profesional         Profesional? @relation(fields: [profesionalId], references: [id])
  servicioId          String?      @map("servicio_id")
  servicio            Servicio?    @relation(fields: [servicioId], references: [id])
  conectorId          String?      @map("conector_id")
  createdAt           DateTime     @default(now()) @map("created_at")

  @@index([fechaDia])
  @@index([mesIdx, anio])
  @@index([entidadId])
  @@index([profesionalId])
  @@index([hashFila])
  @@index([numeroAutorizacion])
  @@map("atenciones")
}

model PresupuestoMensual {
  id        String   @id @default(uuid())
  anio      Int
  mes       Int
  monto     Decimal  @db.Decimal(14, 2)
  notas     String?  @db.Text
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([anio, mes])
  @@map("presupuestos_mensuales")
}
